{
  "_meta": {
    "sources": {
      "tpg": {
        "name": "The Points Guy",
        "url": "https://thepointsguy.com/loyalty-programs/monthly-valuations/",
        "edition": "March 2026",
        "methodology": "Data-driven, 23K data points, weighted by route type. Systematically optimistic. Financial incentive to overvalue (affiliate revenue). Excludes partner awards for airlines but includes them for credit card currencies."
      },
      "up": {
        "name": "Upgraded Points",
        "url": "https://upgradedpoints.com/travel/points-and-miles-valuations/",
        "edition": "March 2026",
        "methodology": "Falls between TPG and conservative sources. Broadest coverage of programs."
      },
      "omaat": {
        "name": "One Mile at a Time (Ben Schlappig)",
        "url": "https://onemileatatime.com/guides/value-miles-points/",
        "edition": "March 2026",
        "methodology": "Intentionally conservative. Values all transferable credit card points equally at 1.7cpp (reflects transfer partner optionality). Independent, no affiliate incentive to inflate."
      },
      "vftw": {
        "name": "View From The Wing (Gary Leff)",
        "url": "https://viewfromthewing.com/value-of-frequent-flyer-miles/",
        "edition": "November 2021",
        "methodology": "Most conservative and theoretically rigorous. Frames value as 'amount at which you are indifferent to holding miles versus cash,' not 'how much airfare a mile can buy.' Accounts for devaluation risk, restricted use, and foregone mile-earning on award tickets. Older data but methodology is the gold standard."
      }
    },
    "last_updated": "2026-05-09",
    "staleness_days": 45,
    "staleness_note": "TPG, UP, and OMAAT update monthly. VFTW updates less frequently. If last_updated is more than 45 days ago, re-fetch from source URLs and update.",
    "methodology": "Each program has a 'floor' (conservative, min across sources) and 'ceiling' (optimistic, max across sources). Default to FLOOR for decision-making. A redemption that beats the ceiling is genuinely exceptional. A redemption below the floor is objectively poor. TPG systematically overvalues; VFTW/OMAAT are more conservative and more useful for 'should I burn points on this?' decisions. See: https://viewfromthewing.com/why-the-points-guy-systematically-overstates-the-value-of-miles/"
  },
