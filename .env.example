# Travel Hacking Toolkit - API Keys
# Copy this file to .env and fill in your keys.
# Only fill in the ones for services you want to use.

# === AWARD FLIGHTS (the good stuff) ===

# Seats.aero - Award flight availability across 25+ mileage programs
# Get a Pro or Partner account at https://seats.aero
SEATS_AERO_API_KEY=

# === FLIGHT SEARCH (cash prices) ===

# Duffel - Primary cash price source. Real GDS per-fare-class data.
# Search is free, pay only if you book. Sign up at https://duffel.com
DUFFEL_API_KEY_LIVE=

# Ignav - Secondary cash price source. Fast REST API.
# 1,000 free requests at https://ignav.com/signup
IGNAV_API_KEY=

# === LOYALTY PROGRAM TRACKING ===

# AwardWallet - Track all your points/miles balances and elite status
# Business account required: https://business.awardwallet.com/profile/api
AWARDWALLET_API_KEY=
AWARDWALLET_USER_ID=

# === HOTELS (optional) ===

# SerpAPI - Google Hotels search and destination discovery
# NOT needed for flights (Duffel and Ignav are better). Hotels and "where should I go?" only.
# Free tier (100 searches/mo) at https://serpapi.com
SERPAPI_API_KEY=

# RapidAPI - Booking.com hotel prices
# Free tier (100 req/month) at https://rapidapi.com
RAPIDAPI_KEY=

# LiteAPI - Hotel search with live rates and booking (remote MCP server)
# Sign up at https://liteapi.travel
LITEAPI_API_KEY=

# TripAdvisor Content API - Hotel ratings, rankings, reviews, photos, nearby search
# 5,000 calls/month. Sign up at https://www.tripadvisor.com/developers
TRIPADVISOR_API_KEY=

# === SCANDINAVIA TRANSIT (optional, for Nordic travel) ===

# Entur (Norway) - Just needs a descriptive client name, not a real key
# Use something like "yourname-tripplanner"
ENTUR_CLIENT_NAME=

# ResRobot (Sweden) - Free key from Trafiklab
# Sign up at https://www.trafiklab.se, create a project, add ResRobot v2.1
RESROBOT_API_KEY=

# Rejseplanen (Denmark) - Free key, requires human review
# Apply at https://labs.rejseplanen.dk. 50,000 calls/month (non-commercial).
REJSEPLANEN_API_KEY=

# === SOUTHWEST (optional) ===

# Your southwest.com login credentials for the change flight monitor
# Not needed for new flight searches (those don't require login)
SW_USERNAME=
SW_PASSWORD=

# === AMERICAN AIRLINES (optional) ===

# Your aa.com login for AAdvantage balance check
# AwardWallet doesn't support AA, so this is the only automated way
AA_USERNAME=
AA_PASSWORD=
# Optional: command to get email 2FA code (blocks until ready, prints to stdout)
# AA_2FA_COMMAND=

# === CHASE TRAVEL PORTAL (optional) ===

# Your chase.com online banking login
# Needed for Chase Travel portal pricing, Points Boost, and Edit hotel search
# Requires a Sapphire Reserve or Sapphire Preferred card
CHASE_USERNAME=
CHASE_PASSWORD=
# Optional: command to get SMS 2FA code (blocks until ready, prints to stdout)
# CHASE_2FA_COMMAND=

# === AMEX TRAVEL PORTAL (optional) ===

# Your americanexpress.com online account login
# Needed for Amex Travel portal pricing, IAP fares, and FHR/THC hotel search
# Requires a Platinum Card for IAP and FHR benefits
AMEX_USERNAME=
AMEX_PASSWORD=
# Optional: command to get email 2FA code (blocks until ready, prints to stdout)
# AMEX_2FA_COMMAND=

# === TICKETSATWORK (optional) ===

# Your ticketsatwork.com login (also works for Working Advantage, Plum
# Benefits, and Beneplace, which all share the same EBG backend).
# Needed only if your employer offers TaW. Used for hotels, theme park
# tickets, attractions, and live events at corporate-perks rates.
TAW_USER=
TAW_PASS=
