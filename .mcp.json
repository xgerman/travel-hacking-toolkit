{
  "mcpServers": {
    "skiplagged": {
      "type": "http",
      "url": "https://mcp.skiplagged.com/mcp"
    },
    "kiwi": {
      "type": "http",
      "url": "https://mcp.kiwi.com"
    },
    "trivago": {
      "type": "http",
      "url": "https://mcp.trivago.com/mcp"
    },
    "ferryhopper": {
      "type": "http",
      "url": "https://mcp.ferryhopper.com/mcp"
    },
    "liteapi": {
      "type": "http",
      "url": "https://mcp.liteapi.travel/api/mcp",
      "headers": {
        "Authorization": "Bearer ${LITEAPI_API_KEY:-unset}"
      }
    },
    "airbnb": {
      "command": "npx",
      "args": [
        "-y",
        "@openbnb/mcp-server-airbnb@latest",
        "--ignore-robots-txt"
      ]
    },
    "documentdb-memory": {
      "command": "documentdb-memory-mcp",
      "env": {
        "DOCUMENTDB_URI": "${DOCUMENTDB_URI:-unset}",
        "DOCUMENTDB_DB": "${DOCUMENTDB_DB:-copilot_memory}",
        "MEMORY_LOG_LEVEL": "${MEMORY_LOG_LEVEL:-info}"
      },
      "args": []
    }
  }
}
